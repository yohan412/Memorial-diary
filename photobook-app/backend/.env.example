# 상위 폴더(test/)의 .env 를 같이 읽습니다. 여기에 두어도 됩니다.

BOOKPRINT_API_KEY=SBxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

BOOKPRINT_BASE_URL=https://api-sandbox.sweetbook.com/v1

# sandbox | live (BOOKPRINT_BASE_URL 이 있으면 무시될 수 있음)

BOOKPRINT_ENV=sandbox

# 썸네일 URL이 storage.sweetbook.com 이 아닌 S3·CDN 인 경우(프록시 403 시)
# 쉼표로 접미사 나열. 예: amazonaws.com,cloudfront.net
# PHOTOBOOK_ASSET_PROXY_HOST_SUFFIXES=amazonaws.com

# Sweetbook 웹훅 수신 서명 검증 (포털 시크릿과 동일하게 설정). 비우면 서명 없이도 수신 저장(개발용).
# PHOTOBOOK_WEBHOOK_SECRET=whsk_xxxxxxxx

# 스토리지가 Referer 를 요구할 때 (기본 https://sweetbook.com/)
# PHOTOBOOK_ASSET_PROXY_REFERER=https://sweetbook.com/

# 썸네일 GET 시 Sweetbook API 키를 함께 보낼지 (대부분 불필요)
# PHOTOBOOK_ASSET_PROXY_SEND_API_KEY=0



# deoldify (기본) | stub — DeOldify 실패 시 stub. 디버깅 시 COLORIZE_FALLBACK_STUB=0

COLORIZE_MODE=deoldify

COLORIZE_FALLBACK_STUB=1

# API 호환용(DeOldify는 텍스트 조건 미사용)

COLORIZE_DEFAULT_PROMPT=color photograph, natural colors

# DeOldify 소스: backend/vendor/DeOldify (git clone thookham/DeOldify)

# PyTorch .pth 를 받을 HF 모델 레포 (기본: spensercai/DeOldify)
# DEOLDIFY_HF_REPO=spensercai/DeOldify

# 가중치 저장: backend/models/deoldify/models/*.pth
# (HF 실패·깨진 파일이면 jantic 공식 미러 Dropbox/deepai 로 자동 폴백)

# DEOLDIFY_ROOT=

# stable | artistic

# DEOLDIFY_VARIANT=stable

# 7~45, 해상도·품질·VRAM (기본 35)

# DEOLDIFY_RENDER_FACTOR=35

# 원본 L 유지 후처리(0|1)

# DEOLDIFY_POST_PROCESS=1


